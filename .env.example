# Copy to .env.local and fill in credentials.
# .env.local is gitignored — never commit real tokens.
#
# Usage:
#   cp .env.example .env.local
#   # fill in the token below
#   .venv/bin/python scripts/smoke.py
#   # or start the server:
#   .venv/bin/python -m sidecar

# ── Provider ──────────────────────────────────────────────────────────────────
# "claude" (default) or "codex"
PROVIDER=claude

# ── Auth mode for scripts/smoke.py ────────────────────────────────────────────
# "auto" (default): the CLI picks up whatever credential is present.
# "subscription":   force the OAuth-token path (CLAUDE_CODE_OAUTH_TOKEN /
#                   ~/.codex/auth.json) — the API key is scrubbed first.
# "api":            force the API-key path (ANTHROPIC_API_KEY / OPENAI_API_KEY)
#                   — the subscription token is scrubbed first.
# Lets you verify each auth path in isolation before deploying.
AUTH_MODE=auto

# ── Claude auth (PROVIDER=claude) ─────────────────────────────────────────────
# LOCAL TESTING ONLY: subscription OAuth token — run `claude setup-token`.
# Never use this for real deployments; production / general use must use
# ANTHROPIC_API_KEY instead.
CLAUDE_CODE_OAUTH_TOKEN=

# Production / general use: API key (pay-as-you-go, from the Anthropic Console)
# ANTHROPIC_API_KEY=sk-ant-...

# "subscription" (default) or "api". Set "api" in production so /readyz requires
# ANTHROPIC_API_KEY specifically instead of accepting a leftover local credential.
# ANTHROPIC_MODE=subscription

# Subscription auth-file location, checked by /readyz (local dev alternative).
# CLAUDE_AUTH_PATH=~/.claude.json

# ── Codex auth (PROVIDER=codex) ───────────────────────────────────────────────
# Option A: API key
# OPENAI_API_KEY=sk-...

# Option B: OAuth subscription (local dev only)
#   Run `codex login` once → creates ~/.codex/auth.json → no env var needed.
#   k8s: the container filesystem is ephemeral, so auth.json disappears on restart.
#   For k8s use OPENAI_API_KEY (Option A), or mount auth.json as a Secret:
#     kubectl create secret generic codex-auth --from-file=auth.json=$HOME/.codex/auth.json
#   then mount it at /root/.codex/auth.json in the sidecar container.
#
# CODEX_AUTH_PATH overrides where the sidecar reads / materializes auth.json.
# CODEX_AUTH_PATH=~/.codex/auth.json

# ── Server ────────────────────────────────────────────────────────────────────
BEARER_SECRET=local-dev-secret
BIND=127.0.0.1
PORT=7300

# ── Tuning ────────────────────────────────────────────────────────────────────
MAX_CONCURRENT=4
TURN_TIMEOUT_SEC=90
CANCEL_GRACE_SEC=5
SHUTDOWN_GRACE_SEC=10
LOG_LEVEL=INFO
LOG_PROMPTS=true

# ── Local workspace (overrides the default /var/lib/... path) ─────────────────
# Non-root / local runs MUST override this — the default /var/lib/claude-sidecar
# path is not writable and startup fails with PermissionError otherwise.
WORKSPACE_ROOT=/tmp/claude-sidecar-sessions

# ── System prompt & MCP (optional) ────────────────────────────────────────────
# Static base system prompt file, re-read on every request (hot-reloadable).
# CLAUDE_MD_PATH=/workspace/CLAUDE.md
# Path to mcp.json for extra static MCP servers (PROVIDER=claude merges these).
# MCP_CONFIG_PATH=/etc/sidecar/mcp.json
# Streamable-HTTP URL of the consumer's domain-tools MCP server. With a per-turn
# X-Turn-Token, the sidecar scopes this server per turn for both providers.
# MCP_SERVER_URL=http://localhost:8080/mcp
# Name of the injected per-turn MCP server entry (defaults to "codecompanion").
# MCP_SERVER_NAME=codecompanion

# ── Observability (optional) ──────────────────────────────────────────────────
# Enable OpenTelemetry tracing; configure the exporter with standard OTEL_* vars.
# TRACING_ENABLED=false
# OTEL_SERVICE_NAME=claude-sidecar
